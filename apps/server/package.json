{
  "name": "@mew/server",
  "version": "0.0.1",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .wrangler",
    "db:migrate:local": "wrangler d1 migrations apply mew --local",
    "db:migrate:remote": "wrangler d1 migrations apply mew --remote",
    "db:studio": "pnpm --filter @mew/database db:studio",
    "db:generate": "pnpm --filter @mew/database db:generate"
  },
  "dependencies": {
    "@mew/ai-core": "workspace:*",
    "@mew/database": "workspace:*",
    "@mew/shared": "workspace:*",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.14",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.0.0"
  }
}
